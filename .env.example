# =============================================================================
# ClawMarket Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Cloudflare (API + Backtest Workers)
# These are configured via `wrangler secret put` for production.
# For local dev, wrangler reads from .dev.vars file.
# -----------------------------------------------------------------------------

# D1 database name (configured in wrangler.jsonc, not here)
# CF_D1_DATABASE_ID=

# -----------------------------------------------------------------------------
# OKX OnchainOS (Wrapped execution gateway)
# -----------------------------------------------------------------------------
OKX_ONCHAINOS_BASE_URL=https://web3.okx.com
OKX_PROJECT_ID=
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# -----------------------------------------------------------------------------
# x402 Payment Configuration
# -----------------------------------------------------------------------------

# Platform treasury address (receives payments)
X402_PAY_TO=0xYOUR_TREASURY_ADDRESS

# Payment stablecoins config (JSON array)
# Default: USDT0 + USDC on X Layer (chain ID 196)
X402_PAYMENT_STABLECOINS_JSON=[{"symbol":"USDT0","address":"0x779Ded0c9e1022225f8E0630b35a9b54bE713736","chainId":196,"signingMethod":"self"},{"symbol":"USDC","address":"0x74b7f16337b8972027f6196a17a631ac6de26d22","chainId":196,"signingMethod":"facilitated"}]

# Platform revenue share in basis points (1000 = 10%)
PLATFORM_REVENUE_SHARE_BPS=1000

# -----------------------------------------------------------------------------
# OpenClaw Skill
# -----------------------------------------------------------------------------
OPENCLAW_SKILL_NAMESPACE=clawmarket

# -----------------------------------------------------------------------------
# Web Frontend (Vite env vars must start with VITE_)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8787

# -----------------------------------------------------------------------------
# Workers AI
# Configured via wrangler.jsonc AI binding. No API key needed.
# -----------------------------------------------------------------------------

# Optional: Override default model
# WORKERS_AI_MODEL=@cf/meta/llama-3.1-8b-instruct
