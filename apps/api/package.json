{
  "name": "@clawmarket/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ClawMarket Hono API on Cloudflare Workers",
  "scripts": {
    "dev": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clawmarket/contracts": "workspace:*",
    "@clawmarket/db": "workspace:*",
    "@hono/zod-validator": "^0.5.0",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "typescript": "latest",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
