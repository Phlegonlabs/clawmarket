{
  "name": "clawmarket-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-14",
  "compatibility_flags": ["nodejs_compat"],

  // D1 Database binding
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "clawmarket-db",
      "database_id": "0d1aec94-4bde-4a36-967e-7b1e11c84c16"
    }
  ],

  // Workers AI binding
  "ai": {
    "binding": "AI"
  },

  // Service bindings (backtest worker)
  "services": [
    {
      "binding": "BACKTEST",
      "service": "clawmarket-backtest"
    }
  ],

  // Environment variables (non-secret defaults)
  "vars": {
    "ENVIRONMENT": "development",
    "PLATFORM_REVENUE_SHARE_BPS": "1000"
  }
}
