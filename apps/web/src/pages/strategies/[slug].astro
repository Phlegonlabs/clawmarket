---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BacktestPanel from "../../components/islands/BacktestPanel";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/strategies");

const API_BASE = import.meta.env.PUBLIC_API_URL ?? "https://api.clawmarket.com";

let strategy: {
  slug: string;
  title: string;
  description: string;
  family: string;
  executionMode: string;
  tags: string[];
  priceUsd: number;
  publisherId: string;
  supportedChainIds: number[];
} | null = null;

let ruleOutline = "";

try {
  const res = await fetch(`${API_BASE}/api/strategies/${slug}`);
  if (res.ok) {
    const json = await res.json() as { data: typeof strategy; display: { markdown: string } };
    strategy = json.data;
    ruleOutline = json.display?.markdown ?? "";
  }
} catch {
  // Will show 404 below
}

if (!strategy) {
  return new Response("Strategy not found", { status: 404 });
}
---

<BaseLayout title={strategy.title} description={strategy.description}>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <!-- Header -->
    <div class="mb-8">
      <div class="mb-2 flex items-center gap-3">
        <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-medium">
          {strategy.family}
        </span>
        <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-medium">
          {strategy.executionMode}
        </span>
      </div>
      <h1 class="text-3xl font-bold">{strategy.title}</h1>
      <p class="mt-2 text-[var(--color-muted-foreground)]">{strategy.description}</p>
    </div>

    <!-- Details grid -->
    <div class="mb-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-card)] p-4">
        <p class="text-xs text-[var(--color-muted-foreground)]">Price</p>
        <p class="mt-1 text-2xl font-bold text-[var(--color-accent)]">${strategy.priceUsd}</p>
        <p class="text-xs text-[var(--color-muted-foreground)]">one-time, permanent access</p>
      </div>
      <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-card)] p-4">
        <p class="text-xs text-[var(--color-muted-foreground)]">Chains</p>
        <p class="mt-1 font-medium">
          {strategy.supportedChainIds.map((id) => id === 196 ? "X Layer" : `Chain ${id}`).join(", ")}
        </p>
      </div>
      <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-card)] p-4">
        <p class="text-xs text-[var(--color-muted-foreground)]">Tags</p>
        <div class="mt-1 flex flex-wrap gap-1">
          {strategy.tags.map((tag) => (
            <span class="rounded-full bg-[var(--color-muted)] px-2 py-0.5 text-xs">{tag}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Purchase guidance -->
    <div class="mb-8 rounded-[var(--radius-lg)] border border-[var(--color-accent)] bg-[var(--color-card)] p-6">
      <h2 class="mb-2 text-lg font-semibold">How to Purchase</h2>
      <p class="text-sm text-[var(--color-muted-foreground)]">
        Use the <a href="/docs/openclaw">OpenClaw skill</a> to purchase this strategy via your AI agent.
        Payment is processed via x402 on X Layer with USDT0 or USDC.
      </p>
    </div>

    <!-- Backtest Panel (React Island) -->
    <div class="mb-8">
      <BacktestPanel slug={slug} client:visible />
    </div>
  </section>
</BaseLayout>
