---
import BaseLayout from "../layouts/BaseLayout.astro";
import LeaderboardTable from "../components/islands/LeaderboardTable";
---

<BaseLayout title="Leaderboard" description="Top trading strategies ranked by performance">
  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="mb-2 text-3xl font-bold">Strategy Leaderboard</h1>
    <p class="mb-8 text-[var(--color-muted-foreground)]">
      Strategies ranked by a composite score: Sharpe ratio, purchases, win rate, recency, and badges.
    </p>
    <LeaderboardTable client:load />
  </section>
</BaseLayout>
