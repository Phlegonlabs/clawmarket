---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] py-8">
  <div class="mx-auto max-w-6xl px-4">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-[var(--color-muted-foreground)]">
        &copy; {year} ClawMarket. Agent-first strategy marketplace.
      </p>
      <div class="flex gap-4 text-sm text-[var(--color-muted-foreground)]">
        <a href="/docs/openclaw" class="hover:text-[var(--color-accent)]">Docs</a>
        <a href="/status" class="hover:text-[var(--color-accent)]">Status</a>
      </div>
    </div>
  </div>
</footer>
