{
  "name": "clawmarket",
  "version": "0.1.0",
  "description": "Agent-first strategy marketplace on OKX X Layer with x402 payments, Cloudflare Workers, and Astro + React Islands.",
  "private": true,
  "type": "module",
  "packageManager": "bun@latest",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check:deps": "dependency-cruiser --config .dependency-cruiser.cjs src --output-type err-long",
    "typecheck": "bun run typecheck:contracts && bun run typecheck:db && bun run typecheck:api && bun run typecheck:backtest",
    "typecheck:contracts": "tsc --project packages/contracts/tsconfig.json --noEmit",
    "typecheck:db": "tsc --project packages/db/tsconfig.json --noEmit",
    "typecheck:api": "tsc --project apps/api/tsconfig.json --noEmit",
    "typecheck:backtest": "tsc --project apps/backtest/tsconfig.json --noEmit",
    "typecheck:root": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check packages apps/api/src apps/backtest/src",
    "format": "biome format --write packages apps/api/src apps/backtest/src",
    "format:check": "biome format packages apps/api/src apps/backtest/src",
    "test": "bun --filter '*' test",
    "build": "echo 'Workspace build — use wrangler for workers'",
    "dev:api": "cd apps/api && wrangler dev",
    "dev:web": "cd apps/web && bun run dev",
    "db:generate": "cd packages/db && bun run generate",
    "db:migrate:local": "cd packages/db && bun run migrate:local",
    "harness:init": "bun .harness/init.ts",
    "harness:init:prd": "bun .harness/init.ts --from-prd",
    "harness:advance": "bun .harness/advance.ts",
    "harness:add-surface": "bun .harness/add-surface.ts",
    "harness:autoflow": "bun .harness/orchestrator.ts --auto",
    "harness:audit": "bun .harness/audit.ts",
    "harness:sync-docs": "bun .harness/sync-docs.ts",
    "harness:sync-skills": "bun .harness/sync-skills.ts",
    "harness:api:add": "bun .harness/api-add.ts",
    "harness:state": "bun .harness/state.ts",
    "harness:env": "bun .harness/validate.ts --env",
    "harness:validate": "bun .harness/validate.ts",
    "harness:validate:phase": "bun .harness/validate.ts --phase",
    "harness:validate:task": "bun .harness/validate.ts --task",
    "harness:validate:milestone": "bun .harness/validate.ts --milestone",
    "harness:guardian": "bun .harness/validate.ts --guardian",
    "harness:resume": "bun .harness/resume.ts",
    "harness:orchestrate": "bun .harness/orchestrator.ts",
    "harness:merge-milestone": "bun .harness/merge-milestone.ts",
    "harness:compact": "bun .harness/compact.ts",
    "harness:compact:milestone": "bun .harness/compact.ts --milestone",
    "harness:compact:status": "bun .harness/compact.ts --status",
    "harness:hooks:install": "bun scripts/harness-local/restore.ts",
    "harness:sync-backlog": "bun .harness/init.ts --sync-from-prd"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/node": "latest",
    "bun-types": "latest",
    "dependency-cruiser": "latest",
    "typescript": "latest"
  }
}
